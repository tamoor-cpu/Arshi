# ---- Core ----
# Local dev uses SQLite. For the pilot, point this at managed Postgres (Neon):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL="file:./dev.db"

# Required. Must be >= 32 chars (server refuses to start otherwise).
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRY="15m"

PORT=4000

# ---- Object storage (optional) ----
# Leave blank to store uploads on local disk (server/uploads).
# Set ALL of these to store uploads & signed PDFs in Cloudflare R2 instead.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Public base URL for the bucket (R2 public dev URL or your custom domain), no trailing slash:
R2_PUBLIC_URL=""

# ---- App URL (for links in invite / password-reset emails) ----
# In production set this to your public app URL, e.g. https://arshi.yourdomain.com
APP_URL=""

# ---- Email (optional; until set, invite/reset links are logged to the server console) ----
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="noreply@arshi.app"

# ---- Error monitoring (optional) ----
# Paste a Sentry DSN to enable error reporting in production. Blank = disabled.
SENTRY_DSN=""

# ---- AI extraction (optional) ----
# Anthropic API key enables "Auto-fill from a manual" (Claude reads a PDF/photo
# and pre-fills equipment records). Blank = the feature is hidden/disabled.
ANTHROPIC_API_KEY=""
# Override the model used for extraction. Default is claude-opus-4-8 (best
# accuracy). For high volume, set to claude-sonnet-4-6 or claude-haiku-4-5 to cut cost.
ANTHROPIC_MODEL=""
